# ========== App ==========
ENV=development
SECRET_KEY=change-me-in-production-use-long-random-string
# Local: DEV_SKIP_AUTH=true usa usuario "dev" sin Microsoft login (solo desarrollo)
DEV_SKIP_AUTH=false
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ========== Database (Azure Database for PostgreSQL) ==========
# Use async driver: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/labeldiff

# ========== Microsoft Entra ID (Azure AD) ==========
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
# Redirect URI registrada en el App Registration (ej: https://yourapp.azurewebsites.net/api/auth/callback)
AZURE_AD_REDIRECT_URI=http://localhost:8000/api/auth/callback
# IDs de grupos de seguridad (Object ID en Azure AD) separados por coma. Prioridad: admin > user > viewer.
AZURE_AD_GROUP_ADMIN=
AZURE_AD_GROUP_USER=
AZURE_AD_GROUP_VIEWER=

# ========== Session cookie (Azure: SameSite=None; Secure=true) ==========
SESSION_SAME_SITE=lax
SESSION_SECURE=false

# ========== Azure Blob Storage ==========
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=etiquetas
SAS_EXPIRY_MINUTES=60

# ========== Gemini (config para el frontend; el frontend llama a la API de Gemini) ==========
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Solo en desarrollo: exponer la clave al frontend vía GET /api/config (no usar en producción)
GEMINI_API_KEY_EXPOSE=false

# ========== Frontend (solo para npm run dev con proxy) ==========
# VITE_API_BASE=  (dejar vacío para mismo origen)
